# Demo-first mode (no MySQL, no persistent storage):
# Uses volatile in-memory session data only.
# Records can be seen in admin after submit, then disappear on refresh.
HOTEL_STORAGE_MODE=volatile
HOTEL_DEMO_VOLATILE=1

# Optional legacy toggle (keep off in volatile mode)
HOTEL_DEMO_SESSION_ONLY=0

# Keep cookie mirror disabled in volatile mode.
HOTEL_DEMO_COOKIE_MIRROR=0
# HOTEL_DEMO_COOKIE_NAME=hotel_demo_store

# One-time reservation handoff (reservation -> first admin listing)
# Keep default values unless you need custom tuning.
HOTEL_HANDOFF_TTL_SECONDS=45
# HOTEL_HANDOFF_SECRET=replace-with-random-secret
# HOTEL_HANDOFF_COOKIE_NAME=hotel_demo_handoff

# Switch to MySQL persistence by changing HOTEL_STORAGE_MODE=mysql
# and setting these values:
# HOTEL_DB_HOST=127.0.0.1
# HOTEL_DB_PORT=3306
# HOTEL_DB_NAME=hotel_reservation_system
# HOTEL_DB_USER=root
# HOTEL_DB_PASS=
# HOTEL_DB_CHARSET=utf8mb4
# HOTEL_DB_AUTO_CREATE_DATABASE=0
