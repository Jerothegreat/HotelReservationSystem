# Demo-first mode (no MySQL writes):
# Uses PHP session storage only and shares data between reservation/admin
# while the browser session remains active.
HOTEL_STORAGE_MODE=session

# Optional legacy toggle (kept for compatibility)
HOTEL_DEMO_SESSION_ONLY=1

# Switch to MySQL persistence by changing HOTEL_STORAGE_MODE=mysql
# and setting these values:
# HOTEL_DB_HOST=127.0.0.1
# HOTEL_DB_PORT=3306
# HOTEL_DB_NAME=hotel_reservation_system
# HOTEL_DB_USER=root
# HOTEL_DB_PASS=
# HOTEL_DB_CHARSET=utf8mb4
# HOTEL_DB_AUTO_CREATE_DATABASE=0
